<script>
(function () {
  var grid = document.querySelector('.dashw-grid');
  if (!grid) return;
  if (!('IntersectionObserver' in window)) { grid.classList.add('dash-run'); return; }
  var io = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) { grid.classList.toggle('dash-run', e.isIntersecting); });
  }, { threshold: 0.12 });
  io.observe(grid);
})();
</script>

