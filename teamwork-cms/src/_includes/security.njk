<!-- ============ SECURITY & COMPLIANCE (shared) ============ -->
<section class="security-tinted-split">
  <div class="container security-split">
    <div class="security-split-text">
      <div class="section-eyebrow">Security & Compliance</div>
      <h2 class="section-title">Certified, audited, and <span class="gradient-text">enterprise-ready.</span></h2>
      <p class="section-sub" style="margin: 0;">Independently verified against the standards your security, finance, and legal teams demand — across every market we serve.</p>
    </div>
    <div class="security-badges-grid">
      <div class="security-badge"><span class="security-badge-icon"><img class="security-badge-logo" src="/assets/images/security/soc-1.png" alt="SOC 1 Type 2"></span><span class="security-badge-name">SOC 1 Type 2</span></div>
      <div class="security-badge"><span class="security-badge-icon"><img class="security-badge-logo" src="/assets/images/security/soc-2.png" alt="SOC 2 Type 2"></span><span class="security-badge-name">SOC 2 Type 2</span></div>
      <div class="security-badge"><span class="security-badge-icon"><img class="security-badge-logo" src="/assets/images/security/iso-27001.png" alt="ISO 27001"></span><span class="security-badge-name">ISO 27001</span></div>
      <div class="security-badge"><span class="security-badge-icon"><img class="security-badge-logo" src="/assets/images/security/gdpr.png" alt="GDPR"></span><span class="security-badge-name">GDPR</span></div>
      <div class="security-badge"><span class="security-badge-icon"><img class="security-badge-logo" src="/assets/images/security/pci-dss.png" alt="PCI DSS"></span><span class="security-badge-name">PCI DSS</span></div>
      <div class="security-badge"><span class="security-badge-icon"><img class="security-badge-logo" src="/assets/images/security/nf525-tse.png" alt="NF525 / TSE"></span><span class="security-badge-name">NF525 / TSE</span></div>
    </div>
  </div>
</section>
