<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<script>
(function () {
  var saved = localStorage.getItem("theme");
  var theme = saved || "dark";
  document.documentElement.setAttribute("data-theme", theme);
})();
</script>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
{% if "Teamwork Commerce" in title %}{% set pageTitle = title %}{% else %}{% set pageTitle = title + " | Teamwork Commerce" %}{% endif %}
<title>{{ pageTitle }}</title>
<meta name="description" content="{{ description }}">
<link rel="canonical" href="https://www.teamworkcommerce.com{{ page.url }}">

<!-- Favicon -->
<link rel="icon" type="image/svg+xml" href="/assets/images/favicon.svg">
<link rel="icon" type="image/png" sizes="32x32" href="/assets/images/favicon-32x32.png">
<link rel="icon" type="image/png" sizes="16x16" href="/assets/images/favicon-16x16.png">
<link rel="shortcut icon" href="/assets/images/favicon.ico">
<link rel="apple-touch-icon" sizes="180x180" href="/assets/images/apple-touch-icon.png">

<!-- Open Graph -->
<meta property="og:type" content="website">
<meta property="og:title" content="{{ pageTitle }}">
<meta property="og:description" content="{{ description }}">
<meta property="og:url" content="https://www.teamworkcommerce.com{{ page.url }}">
<meta property="og:image" content="https://www.teamworkcommerce.com/assets/images/og-image.png">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:site_name" content="Teamwork Commerce">

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ pageTitle }}">
<meta name="twitter:description" content="{{ description }}">
<meta name="twitter:image" content="https://www.teamworkcommerce.com/assets/images/og-image.png">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=IBM+Plex+Sans:wght@600;700;800&family=IBM+Plex+Mono:wght@400;500;600&display=swap">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.4.0/dist/tabler-icons.min.css">
<link rel="stylesheet" href="/assets/css/style.css?v={{ buildVersion }}">

<!-- Organization Schema (AEO: entity identity) -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Teamwork Commerce",
  "url": "https://www.teamworkcommerce.com",
  "logo": "https://www.teamworkcommerce.com/assets/images/teamwork-logo-color.svg",
  "description": "Teamwork Commerce is a global, AI-enabled retail platform providing enterprise POS, OMS, Inventory Management, and RFID solutions. One natively integrated system powering 30,000+ terminals across 40+ countries with 99.99% uptime.",
  "foundingDate": "1994",
  "sameAs": [
    "https://www.linkedin.com/company/teamwork-commerce/",
    "https://www.youtube.com/@teamworkcommerce6746",
    "https://www.instagram.com/teamworkcommerce/"
  ],
  "areaServed": "Worldwide",
  "numberOfEmployees": {
    "@type": "QuantitativeValue",
    "value": "200+"
  }
}
</script>

<!-- SoftwareApplication Schema (AEO: structured product identity) -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Teamwork Commerce",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "iOS, Cloud",
  "description": "Natively integrated enterprise POS, with OMS, Inventory Management, RFID, and AI as extras that make it stronger — for mid-market and enterprise retailers.",
  "featureList": [
    "Mobile-first iOS-native POS",
    "Distributed Order Management with AI routing",
    "Real-time Inventory Management",
    "Native end-to-end RFID (99.9% accuracy)",
    "121 Commerce — Plus-tier AI guidance for associates",
    "Fiscal compliance in 40+ countries",
    "Store-and-Forward offline resilience",
    "150+ pre-configured analytics reports",
    "SOC 2 Type 2, GDPR, PCI DSS compliant"
  ]
}
</script>

<!-- BreadcrumbList Schema (AEO: page hierarchy) -->
{% set rawSegments = page.url.split('/') %}
{% set crumbName = navLabel or title %}
{% if rawSegments.length == 3 %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.teamworkcommerce.com/" },
    { "@type": "ListItem", "position": 2, "name": {{ crumbName | dump | safe }}, "item": "https://www.teamworkcommerce.com{{ page.url }}" }
  ]
}
</script>
{% elif rawSegments.length >= 4 %}
{% if rawSegments[1] == "platform" %}
  {% set categoryName = "Platform" %}
  {% set categoryUrl = "/platform/tcs/" %}
{% elif rawSegments[1] == "solutions" %}
  {% set categoryName = "Solutions" %}
  {% set categoryUrl = "/solutions/" %}
{% else %}
  {% set categoryName = rawSegments[1] | capitalize %}
  {% set categoryUrl = "/" + rawSegments[1] + "/" %}
{% endif %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.teamworkcommerce.com/" },
    { "@type": "ListItem", "position": 2, "name": {{ categoryName | dump | safe }}, "item": "https://www.teamworkcommerce.com{{ categoryUrl }}" },
    { "@type": "ListItem", "position": 3, "name": {{ crumbName | dump | safe }}, "item": "https://www.teamworkcommerce.com{{ page.url }}" }
  ]
}
</script>
{% endif %}
</head>
<body>

{% include "nav.njk" %}

<main>
{{ content | safe }}
</main>

{% include "footer.njk" %}

<script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
<script>
if (window.netlifyIdentity) {
  window.netlifyIdentity.on("init", user => {
    if (!user) {
      window.netlifyIdentity.on("login", () => { document.location.href = "/admin/"; });
    }
  });
}
</script>
<script>
(function () {
  var themeToggle = document.getElementById("themeToggle");
  var themeIcon = document.getElementById("themeIcon");

  function setIcon(theme) {
    if (!themeIcon) return;
    themeIcon.classList.toggle("ti-sun", theme === "light");
    themeIcon.classList.toggle("ti-moon", theme === "dark");
  }
  setIcon(document.documentElement.getAttribute("data-theme"));

  if (themeToggle) {
    themeToggle.addEventListener("click", function () {
      var current = document.documentElement.getAttribute("data-theme");
      var next = current === "dark" ? "light" : "dark";
      document.documentElement.setAttribute("data-theme", next);
      localStorage.setItem("theme", next);
      setIcon(next);
    });
  }

  var navEl = document.querySelector(".nav");
  if (navEl) {
    function navScrollState() {
      navEl.classList.toggle("nav-scrolled", (window.scrollY || document.documentElement.scrollTop) > 8);
    }
    window.addEventListener("scroll", navScrollState, { passive: true });
    navScrollState();
  }

  var navHamburger = document.getElementById("navHamburger");
  var navMobileMenu = document.getElementById("navMobileMenu");
  if (navHamburger && navMobileMenu) {
    navHamburger.addEventListener("click", function () {
      navMobileMenu.classList.toggle("open");
    });
  }

  var reduceMotionReveal = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  if (!reduceMotionReveal && "IntersectionObserver" in window) {
    var revealSelector = [
      ".section-header", ".feature-row", ".pillar-card", ".quote-card", ".metric-card",
      ".rollout-step", ".capcol", ".edge-card", ".intg-card", ".blog-card", ".vs-panel",
      ".sp-wrap", ".svc-card", ".innov-card", ".worldmap-wrap", ".rfid-shot", ".omni-split",
      ".ticker-item", ".captabs-nav", ".captab-panel.active", ".midcta-inner", ".metrics-text", ".rcpt-wrap"
    ].join(", ");
    var revealEls = document.querySelectorAll(revealSelector);
    var lastParent = null, siblingIndex = 0;
    revealEls.forEach(function (el) {
      if (el.parentElement === lastParent) { siblingIndex++; } else { lastParent = el.parentElement; siblingIndex = 0; }
      el.style.setProperty("--reveal-delay", Math.min(siblingIndex * 0.07, 0.42) + "s");
      el.classList.add("reveal");
    });
    var revealObserver = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add("in-view");
          revealObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.12, rootMargin: "0px 0px -6% 0px" });
    revealEls.forEach(function (el) { revealObserver.observe(el); });

    // Fail-open fallback: rect-based check so content can never stay hidden
    // if IntersectionObserver misbehaves in an embedded/odd environment.
    var revealTick = false;
    function revealSweep() {
      revealTick = false;
      var vh = window.innerHeight || document.documentElement.clientHeight;
      revealEls.forEach(function (el) {
        if (el.classList.contains("in-view")) return;
        var r = el.getBoundingClientRect();
        if (r.top < vh * 0.94 && r.bottom > 0) el.classList.add("in-view");
      });
    }
    function queueSweep() {
      if (!revealTick) { revealTick = true; requestAnimationFrame(revealSweep); }
    }
    window.addEventListener("scroll", queueSweep, { passive: true });
    window.addEventListener("resize", queueSweep, { passive: true });
    window.addEventListener("load", revealSweep);
    revealSweep();
  }

  // ---- The Live Store: simulated global ops feed ----
  var heroFeed = document.getElementById("heroFeed");
  var mapFeed = document.getElementById("mapFeed");
  {
    var LF_EVENTS = [
      ["pos", "Tap to Pay approved — <strong>Melbourne Central</strong>"],
      ["fiscal", "NF525 receipt signed — <strong>Paris Le Marais</strong>"],
      ["rfid", "RFID cycle count: 4,208 items in 2m 11s — <strong>Tokyo Ginza</strong>"],
      ["omni", "BOPIS order picked up — <strong>Store #114, Austin</strong>"],
      ["pos", "121 Commerce recommendation accepted — <strong>NYC SoHo</strong>"],
      ["fiscal", "TSE transaction logged — <strong>Berlin Mitte</strong>"],
      ["omni", "Endless Aisle: size 11 shipped from <strong>Dallas DC</strong>"],
      ["rfid", "Self-checkout: 8 items in 2.4s — <strong>Osaka Umeda</strong>"],
      ["pos", "Store-and-Forward sync complete — <strong>Zermatt</strong> (offline 14m)"],
      ["omni", "Return restocked in real time — <strong>London Regent St</strong>"],
      ["fiscal", "CFDI invoice issued — <strong>Mexico City Polanco</strong>"],
      ["pos", "Loyalty sign-up via QR — <strong>Singapore Orchard</strong>"],
      ["omni", "Ship-from-store label printed — <strong>Toronto Eaton Centre</strong>"],
      ["rfid", "EAS gate verified 3 items sold — <strong>Stockholm City</strong>"]
    ];
    var LF_TAGS = { pos: "POS", rfid: "RFID", omni: "OMNI", fiscal: "FISCAL" };
    var lfIdx = Math.floor(Math.random() * LF_EVENTS.length);
    var reduceLf = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    function lfTime() {
      var d = new Date();
      function p(n) { return (n < 10 ? "0" : "") + n; }
      return p(d.getHours()) + ":" + p(d.getMinutes()) + ":" + p(d.getSeconds());
    }
    function lfRow(ev) {
      var row = document.createElement("div");
      row.className = "lf-row";
      row.innerHTML = '<span class="lf-time">' + lfTime() + '</span><span class="lf-text">' + ev[1] + '</span><span class="lf-tag lf-tag-' + ev[0] + '">' + LF_TAGS[ev[0]] + '</span>';
      return row;
    }
    function lfNext() { lfIdx = (lfIdx + 1) % LF_EVENTS.length; return LF_EVENTS[lfIdx]; }

    if (heroFeed) {
      for (var i = 0; i < 5; i++) heroFeed.appendChild(lfRow(lfNext()));
      if (!reduceLf) {
        setInterval(function () {
          heroFeed.insertBefore(lfRow(lfNext()), heroFeed.firstChild);
          while (heroFeed.children.length > 5) heroFeed.removeChild(heroFeed.lastChild);
        }, 3400);
      }
    }
    if (mapFeed) {
      function mapTick() {
        var ev = lfNext();
        mapFeed.innerHTML = '<span class="lf-time">' + lfTime() + '</span>' + ev[1];
      }
      mapTick();
      if (!reduceLf) setInterval(mapTick, 3000);
    }

    // Single-line rotating event feeds: [data-live-line]
    document.querySelectorAll("[data-live-line]").forEach(function (el) {
      var idx = Math.floor(Math.random() * LF_EVENTS.length);
      function lineTick() {
        idx = (idx + 1) % LF_EVENTS.length;
        el.innerHTML = '<span class="lf-time">' + lfTime() + '</span> ' + LF_EVENTS[idx][1];
      }
      lineTick();
      if (!reduceLf) setInterval(lineTick, 3200);
    });

    // Shared live counters/clocks (any page): [data-live-tx] [data-live-reg] [data-live-clock]
    var txEls = document.querySelectorAll("[data-live-tx]");
    var regEls = document.querySelectorAll("[data-live-reg]");
    var clockEls = document.querySelectorAll("[data-live-clock]");
    function setAll(els, text) { els.forEach(function (el) { el.textContent = text; }); }
    var d0 = new Date();
    var txCount = Math.floor((d0.getHours() * 3600 + d0.getMinutes() * 60 + d0.getSeconds()) * 26.3);
    setAll(txEls, txCount.toLocaleString("en-US"));
    setAll(clockEls, lfTime());
    if (!reduceLf && (txEls.length || regEls.length || clockEls.length)) {
      setInterval(function () { setAll(clockEls, lfTime()); }, 1000);
      setInterval(function () {
        txCount += 18 + Math.floor(Math.random() * 35);
        setAll(txEls, txCount.toLocaleString("en-US"));
        if (Math.random() < 0.3) setAll(regEls, (30408 + Math.floor(Math.random() * 9)).toLocaleString("en-US"));
      }, 1400);
    }

    // Live RFID scan counter: [data-live-scan] counts items up per zone, then moves on
    document.querySelectorAll("[data-live-scan]").forEach(function (el) {
      var zoneEl = el.parentElement.querySelector("[data-live-zone]");
      if (reduceLf) { el.textContent = "4,208"; return; }
      var count = 0, target = 3400 + Math.floor(Math.random() * 1600), zone = 1;
      setInterval(function () {
        if (count < target) {
          count = Math.min(target, count + 40 + Math.floor(Math.random() * 90));
        } else {
          zone = (zone % 6) + 1; count = 0; target = 3400 + Math.floor(Math.random() * 1600);
          if (zoneEl) zoneEl.textContent = zone;
        }
        el.textContent = count.toLocaleString("en-US");
      }, 90);
    });

    // "A day in your store": highlight the stop matching the visitor's local time
    var dayStops = document.querySelectorAll("[data-day-time]");
    if (dayStops.length) {
      var now = new Date();
      var nowMin = now.getHours() * 60 + now.getMinutes();
      var current = null;
      dayStops.forEach(function (el) {
        var t = el.getAttribute("data-day-time").split(":");
        var m = parseInt(t[0], 10) * 60 + parseInt(t[1], 10);
        if (m <= nowMin) current = el;
      });
      if (!current) current = dayStops[dayStops.length - 1];
      current.classList.add("day-now");
    }
  }

  document.querySelectorAll("[data-rail]").forEach(function (rail) {
    var wrap = rail.parentElement;
    var step = function () { var card = rail.querySelector(".cs-card"); return card ? card.getBoundingClientRect().width + 18 : 380; };
    var prev = wrap.querySelector("[data-rail-prev]");
    var next = wrap.querySelector("[data-rail-next]");
    if (prev) prev.addEventListener("click", function () { rail.scrollBy({ left: -step(), behavior: "smooth" }); });
    if (next) next.addEventListener("click", function () { rail.scrollBy({ left: step(), behavior: "smooth" }); });
  });

  var captabs = document.querySelectorAll(".captab");
  var capPanels = document.querySelectorAll(".captab-panel");
  captabs.forEach(function (tab) {
    tab.addEventListener("click", function () {
      captabs.forEach(function (t) { t.classList.remove("active"); t.setAttribute("aria-selected", "false"); });
      capPanels.forEach(function (p) { p.classList.remove("active"); });
      tab.classList.add("active");
      tab.setAttribute("aria-selected", "true");
      var panel = document.getElementById(tab.getAttribute("data-captab"));
      if (panel) panel.classList.add("active");
    });
  });

  var counters = document.querySelectorAll(".counter[data-target]");
  if (counters.length) {
    var reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    function render(el, value, decimals, suffix) {
      el.textContent = value.toFixed(decimals) + suffix;
    }

    function animate(el) {
      var target = parseFloat(el.getAttribute("data-target"));
      var suffix = el.getAttribute("data-suffix") || "";
      var decimals = (el.getAttribute("data-target").split(".")[1] || "").length;
      if (reduceMotion) { render(el, target, decimals, suffix); return; }
      render(el, 0, decimals, suffix);
      var duration = 1400;
      var start = null;
      function step(ts) {
        if (start === null) start = ts;
        var progress = Math.min((ts - start) / duration, 1);
        var eased = 1 - Math.pow(1 - progress, 3);
        render(el, target * eased, decimals, suffix);
        if (progress < 1) requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
    }

    if ("IntersectionObserver" in window) {
      var seen = new WeakSet();
      var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting && !seen.has(entry.target)) {
            seen.add(entry.target);
            animate(entry.target);
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.4 });
      counters.forEach(function (el) { observer.observe(el); });
    } else {
      counters.forEach(animate);
    }
  }
})();
</script>
</body>
</html>
